# ─────────────────────────────────────────────────────────────
# 운영(GPU 서버)용 기본값입니다. Mac 로컬에서 Ollama로 돌리려면
# 아래 "Mac 로컬 (Ollama)" 섹션의 값으로 덮어쓰세요.
# ─────────────────────────────────────────────────────────────

# ── VLM (GPU 0) ──
VLM_HOST=localhost
VLM_PORT=8001
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct-AWQ

# ── LLM (GPU 1) ──
LLM_HOST=localhost
LLM_PORT=8002
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# ── 임베딩 ──
EMBEDDING_MODEL=BAAI/bge-m3

# ── 저장소 ──
CHROMA_PERSIST_DIR=./data/chroma_db
BM25_INDEX_DIR=./data/bm25_index
UPLOAD_DIR=./data/uploads
IMAGE_DIR=./data/images

# ── Langfuse ──
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── 청킹 ──
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── 검색 ──
TOP_K=5
RRF_K=60
FAITHFULNESS_THRESHOLD=0.7
MAX_RETRIES=2

# ─────────────────────────────────────────────────────────────
# Mac 로컬 (Ollama)
#   `brew install ollama && brew services start ollama`
#   경량 (Mac 데모용, ~2GB):  `ollama pull qwen2.5:3b`
#   고품질 (M1 Pro 이상 권장):`ollama pull qwen2.5:7b && ollama pull llava:7b`
# 받은 모델 이름에 맞춰 LLM_MODEL/VLM_MODEL을 바꿔 .env에 작성하세요.
# ─────────────────────────────────────────────────────────────
# LLM_HOST=localhost
# LLM_PORT=11434
# LLM_MODEL=qwen2.5:3b
# VLM_HOST=localhost
# VLM_PORT=11434
# VLM_MODEL=llava:7b
