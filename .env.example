# ── VLM (GPU 0) ──
VLM_HOST=localhost
VLM_PORT=8001
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct-AWQ

# ── LLM (GPU 1) ──
LLM_HOST=localhost
LLM_PORT=8002
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# ── 임베딩 ──
EMBEDDING_MODEL=BAAI/bge-m3

# ── 저장소 ──
CHROMA_PERSIST_DIR=./data/chroma_db
BM25_INDEX_DIR=./data/bm25_index
UPLOAD_DIR=./data/uploads
IMAGE_DIR=./data/images

# ── Langfuse ──
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── 청킹 ──
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── 검색 ──
TOP_K=5
RRF_K=60
FAITHFULNESS_THRESHOLD=0.7
MAX_RETRIES=2
